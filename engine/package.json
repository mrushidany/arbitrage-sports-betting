{
  "name": "arb-engine",
  "version": "0.1.0",
  "description": "Sports arbitrage scanning engine — multi-bookmaker odds scanner with Telegram alerts",
  "private": true,
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "ts-node src/main.ts",
    "scan:once": "ts-node src/scan-once.ts",
    "debug:match": "ts-node src/debug-match.ts",
    "stats": "ts-node src/stats.ts",
    "telegram:test": "ts-node src/telegram-test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^6.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  }
}
