# --- Scanner ---
SCAN_INTERVAL_SEC=60        # seconds between scan cycles
MIN_PROFIT_PCT=0.5          # ignore arbs below this guaranteed % (pre-tax)
TOTAL_STAKE=100000          # bankroll per arb, used for stake-split math
WIN_TAX_PCT=18              # withholding tax on net winnings (Tanzania GBT = 18%). Set 0 to disable.
CURRENCY=TZS

# --- Telegram alerts ---
# 1. Talk to @BotFather on Telegram -> /newbot -> copy the token
# 2. Message your new bot once, then open
#    https://api.telegram.org/bot<TOKEN>/getUpdates and copy chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DATABASE_URL="file:../data/arb.db"

# --- HTTP API (consumed by the dashboard) ---
PORT=5001
CORS_ORIGIN=http://localhost:5000
